# =============================================================
# MoneyFlow Environment Configuration
# =============================================================
# IMPORTANT: Copy this file to .env and fill in real values.
#            NEVER commit the actual .env file to version control.
# =============================================================

# --- MySQL Root ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password_here

# --- Application Database ---
MYSQL_DATABASE=moneyflow_db
MYSQL_USER=moneyflow_admin
MYSQL_PASSWORD=CHANGE_ME_db_password_here

# --- Application Secrets ---
HMAC_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- Database Connection (used by web container) ---
DATABASE_HOST=db
DATABASE_NAME=moneyflow_db
DATABASE_USER=moneyflow_admin
DATABASE_PASS=CHANGE_ME_db_password_here

# --- PHP / Apache ---
PHP_DISPLAY_ERRORS=0
PHP_LOG_ERRORS=1
