# =============================================================
# MoneyFlow Environment Configuration — TEMPLATE
# =============================================================
# Copy this file to .env and replace all placeholder values
# with strong, unique secrets before starting the application.
#
#   cp .env.example .env
#   # Then edit .env with your own values
# =============================================================

# MySQL Root Password (used for DB initialization only)
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password_here

# MySQL Database Configuration
MYSQL_DATABASE=moneyflow_db
MYSQL_USER=moneyflow_admin
MYSQL_PASSWORD=CHANGE_ME_db_password_here

# Application Database Connection
DATABASE_HOST=db
DATABASE_NAME=moneyflow_db
DATABASE_USER=moneyflow_admin
DATABASE_PASS=CHANGE_ME_db_password_here

# HMAC Secret for Token Signing (use: openssl rand -hex 32)
HMAC_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Web Server Port (host port mapped to container port 80)
WEB_PORT=8080

# Environment (development / production)
APP_ENV=development
